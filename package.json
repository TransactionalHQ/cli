{
  "name": "@transactional/cli",
  "version": "0.1.0",
  "description": "Official CLI for Transactional - manage email, SMS, forms, and more from your terminal",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "transactional": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "inquirer": "^10.2.2",
    "nanoid": "^5.0.9",
    "open": "^10.1.0",
    "ora": "^8.1.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "transactional",
    "email",
    "sms",
    "cli",
    "api"
  ],
  "author": "Transactional",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/transactionalHQ/cli"
  },
  "homepage": "https://usetransactional.com",
  "engines": {
    "node": ">=18.0.0"
  }
}
