{
  "name": "@usetransactional/cli",
  "version": "0.1.0",
  "description": "CLI tool for Transactional — send emails, SMS, manage domains from the terminal",
  "bin": {
    "transactional": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "type": "module",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "open": "^10.0.0",
    "ora": "^8.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["transactional", "cli", "email", "sms", "api"],
  "author": "Transactional <support@usetransactional.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TransactionalHQ/cli.git"
  }
}
